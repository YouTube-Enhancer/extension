{
	"compilerOptions": {
		"target": "esnext",
		"types": ["vite/client", "node", "chrome"],
		"lib": ["dom", "dom.iterable", "esnext"],
		"moduleDetection": "force",
		"verbatimModuleSyntax": true,
		"allowJs": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noFallthroughCasesInSwitch": true,
		"module": "preserve",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"paths": {
			"@/public/locales/*": ["./public/locales/*"],
			"@/src/*": ["./src/*"],
			"@/assets/*": ["./src/assets/*"],
			"@/pages/*": ["./src/pages/*"],
			"@/components/*": ["./src/components/*"],
			"@/utils": ["./src/utils/index"],
			"@/utils/*": ["./src/utils/*"],
			"@/hooks": ["./src/hooks/index"],
			"@/hooks/*": ["./src/hooks/*"],
			"monaco-editor/esm/*": ["./node_modules/monaco-editor/esm/*"],
			"youtubei.js/dist/*": ["./node_modules/youtubei.js/dist/*"],
			"rollup/*": ["./node_modules/rollup/dist/*"],
			"vite/*": ["./node_modules/vite/*"],
			"playwright.config": ["./playwright.config.ts"],
			"playwright-core/types/*": ["./node_modules/playwright-core/types/*"],
			"youtube-player/dist/types/*": ["./node_modules/youtube-player/dist/types/*"]
		}
	},
	"include": [
		"src",
		"vite.config.ts",
		"public/locales",
		"playwright.config.ts",
		"tailwind.config.ts",
		"postcss.config.cjs",
		"prettier.config.mjs",
		"src/features/__tests__",
		"eslint.config.mjs"
	],
	"exclude": ["node_modules", "dist", "releases"]
}
